# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=security_scanner
DATABASE_URL=postgres://postgres:your_secure_password_here@postgres:5432/security_scanner

# JWT Secret (Generate a random string!)
JWT_SECRET=generate-a-random-secret-key-here

# API Configuration
API_PORT=5000
FRONTEND_PORT=3000

# ZAP Configuration
ZAP_API_URL=http://security-scanner-zap:8090

# Scanner Configuration
SCANNER_CONTAINER=security-scanner-tools

# Node Environment
NODE_ENV=development
